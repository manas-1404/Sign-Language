INFERENCE_MODE=api
GOOGLE_API_KEY=your_google_api_key_here

# Shared secret checked on every /analyze request — must match MODAL_PROXY_API_SECRET in frontend .env.local
# and in the Modal Secret named 'sign-language-secrets'
MODAL_PROXY_API_SECRET=your_shared_secret_here

# Debug: set to true to save every incoming webcam frame to backend/debug_images/
SAVE_DEBUG_IMAGES=false
